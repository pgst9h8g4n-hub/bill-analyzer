# 后端环境变量配置
# 在 Railway Dashboard → Variables 中设置这些值

# Supabase 配置
SUPABASE_URL=https://spzxyecryqenludsrrrn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<你的service_role_key>

# PostgreSQL 直连（Railway 会自动提供 DATABASE_URL）
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# 安全
SECRET_KEY=<生成一个随机密钥>

# CORS（允许前端访问）
ALLOWED_ORIGINS=https://bill-analyzer-332.pages.dev
